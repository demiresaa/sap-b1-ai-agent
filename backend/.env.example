# ============================================================
# SAP B1 AI Agent — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayıp gerçek değerlerle doldurun.
# .env DOSYASINI ASLA git'e commit ETMEYİN.
# ============================================================

# --- Uygulama ---
APP_ENV=development
APP_SECRET_KEY=change-me-with-openssl-rand-hex-32
APP_BASE_URL=http://localhost:8000

# --- Veritabanı ---
DATABASE_URL=postgresql+asyncpg://sapai:sapai@localhost:5432/sapai
REDIS_URL=redis://localhost:6379/0

# --- Celery ---
# Dev'de False bırak (FastAPI BackgroundTasks ile aynı process'te çalışır,
# ekstra worker başlatmana gerek kalmaz). Prod'da True yapıp `celery -A app.workers.celery_app worker`
CELERY_ENABLED=false

# --- SAP B1 Service Layer ---
SAP_SERVICE_LAYER_URL=https://sap-host:50000/b1s/v1
SAP_COMPANY_DB=SBODEMOTR
SAP_USERNAME=manager
SAP_PASSWORD=
SAP_VERIFY_SSL=false
SAP_SESSION_TIMEOUT_MINUTES=30
SAP_MAX_CONCURRENT_SESSIONS=4
# true: SAP'a YAZMA, sadece JSON payload üret ve UI'da göster (test için).
# false: gerçek SAP Service Layer'a POST atar.
SAP_DRY_RUN=true

# --- OpenRouter (OpenAI-uyumlu; Claude/GPT/Gemini tek API) ---
# API key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Model ID formatı: "vendor/model" — https://openrouter.ai/models
LLM_MODEL_DEFAULT=anthropic/claude-sonnet-4.5
LLM_MODEL_HARD=anthropic/claude-opus-4.1
LLM_MODEL_FAST=anthropic/claude-haiku-4.5
# OpenRouter dashboard'da görünmek için (opsiyonel)
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=SAP B1 AI Agent

# --- E-posta inbox (IMAP) ---
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FOLDER=INBOX
EMAIL_POLL_INTERVAL_SECONDS=300

# --- Observability ---
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- JWT ---
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7
